class Solution {
    public static int nthDay(int d, int n) {
        // Calculate the day index by subtracting n from d.
        // We use (d - (n % 7) + 7) % 7 to ensure the result is 
        // always a positive index between 0 and 6.
        int result = (d - (n % 7) + 7) % 7;
        
        return result;
    }
}
